---
import aspectloafykitten from '@/assets/images/aspect-loafykitten.png'
import bgVt from '@/assets/images/bg-vt.png'
import IslandLayout from '@/layouts/IslandLayout.astro'
import type { BgImageMetadata } from '@/types'
import { Image } from 'astro:assets'

const contentTitles = [
    'Lofi Creation',
    'Live Programming',
    'Detroit Become Human',
    'Palworld',
    'Elden Ring',
    'Cyberpunk 2077',
]

const background: BgImageMetadata = {
    url: bgVt,
    artistMetadata: {
        artist: 'Miklaws',
        artistUrl: 'https://pixabay.com/users/miklaws-20160080/',
    },
    pageBg: '#3971a5',
}
---

<IslandLayout
    title="streams and stuff"
    description="loafykitten — a silly little VTuber, software engineer, and lofi artist streaming most nights at ~9pm CST."
    bgImageMetadata={background}
>
    <section class="info-shell">
        <div class="info-container">
            <a href="/" class="home-link">home</a>
            <div class="author">
                <div class="author-identity">
                    <div class="author-avatar">
                        <Image src={aspectloafykitten} alt="loafykitten avatar" />
                    </div>
                    <h2 class="author-name">
                        <span class="author-name__primary">Loafy</span>
                        <span class="author-name__secondary">// loafykitten</span>
                    </h2>
                </div>
                <nav>
                    <a
                        class="twitch"
                        href="https://www.twitch.tv/caffeineplz"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        Twitch »
                    </a>
                    <a
                        class="youtube"
                        href="https://www.youtube.com/@loafykitten"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        YouTube »
                    </a>
                    <a class="tip" href="https://www.ko-fi.com/loafykitten" target="_blank" rel="noopener noreferrer">
                        Tip Me ꨄ »
                    </a>
                </nav>
            </div>

            <div class="content">
                <div class="bio">
                    <h1>Biography</h1>

                    <p>Hi, I'm your friendly neighborhood VTuber!</p>

                    <p>
                        A silly little software engineer, lofi artist, and low energy streamer. You can find me most
                        nights at ~9pm CST!
                    </p>
                </div>
                <div class="streams">
                    <h1>Recent Streams</h1>
                    <div class="content-pills">
                        {contentTitles.map((title) => <span>{title}</span>)}
                    </div>
                </div>
            </div>
        </div>
    </section>
</IslandLayout>

<style>
    .author,
    .content {
        transform: translateX(0);
        transition: transform 0.3s ease;

        &:hover {
            transform: translateX(5px);
        }
    }

    .info-shell {
        display: flex;
        flex: 1;
        flex-direction: column;
        justify-content: center;
        padding-bottom: 0;
    }

    .info-container {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
        padding: 3rem;
        box-sizing: border-box;
        animation: fadeInUp 1s ease-out;
    }

    .author {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        border: 1px solid #ddd1;
        padding: 1rem;
        border-radius: 8px;
        background-color: #000b;
    }

    .author-identity {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 1.25rem;
    }

    .author-name {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.1rem;
        margin: 0;
        line-height: 1.05;
        text-shadow: 0 0 3px var(--color-loafykitten);
    }

    .author-name__primary {
        font-weight: 300;
        font-size: 1.35rem;
        letter-spacing: 0.04rem;
    }

    .author-name__secondary {
        font-weight: 200;
        font-size: 0.92rem;
        letter-spacing: 0.06rem;
        opacity: 0.72;
    }

    .author-avatar {
        img {
            aspect-ratio: 1 / 1;
            width: 100px;
            height: 100px;
            border: 3px solid var(--color-loafykitten);
            border-radius: 50%;
            display: block;
            transform: scale(1);
            will-change: transform;
            transition:
                transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.4s;

            &:hover {
                transform: scale(1.05) rotate(5deg);
                box-shadow: 0 0 10px var(--color-loafykitten);
            }
        }
    }

    nav {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        justify-content: center;
        align-items: end;

        a.twitch {
            color: #9147ff;

            &:after {
                background-color: #9147ff;
            }
        }

        a.youtube {
            color: #f00;

            &:after {
                background-color: #f00;
            }
        }

        a.tip {
            color: #bdeebb;

            &:after {
                background-color: #bdeebb;
            }
        }

        a {
            text-decoration: none;
            font-size: 1.2rem;
            font-weight: 300;
            letter-spacing: 0.03em;
            position: relative;
            transform: scale(1);
            transition: transform 0.2s ease;

            &:hover {
                transform: scale(1.05);
            }

            &:after {
                content: '';
                position: absolute;
                left: 0;
                bottom: -2px;
                width: 100%;
                height: 2px;
                transform: scaleX(0);
                transform-origin: right;
                transition: transform 0.3s ease;
            }

            &:hover:after {
                transform: scaleX(1);
                transform-origin: left;
            }
        }
    }

    .content {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        border: 1px solid #ddd1;
        padding: 1rem;
        border-radius: 8px;
        background-color: #000b;
    }

    .bio {
        display: flex;
        flex-direction: column;
        justify-content: center;

        & p {
            margin-top: 0.5rem;
        }

        & span {
            font-size: 0.8rem;
            font-style: italic;
        }
    }

    .streams {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.5rem;
    }

    .content-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;

        span {
            background-color: #fff2;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.8rem;
            font-weight: 300;
            transform: translateY(0);
            transition:
                background-color 0.3s ease,
                transform 0.3s ease;

            &:hover {
                background-color: #fff4;
                transform: translateY(-2px);
            }
        }
    }

    p {
        font-size: 0.9rem;
        line-height: 1.5;
        text-align: left;

        &:hover {
            transform: translateX(5px);
        }
    }

    h1 {
        text-align: left;
        margin-bottom: 0.5rem;
        font-weight: 300;
        font-size: 1.1rem;
    }

    .home-link {
        display: inline-block;
        color: var(--color-loafykitten);
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 200;
        letter-spacing: 0.05em;
        margin-bottom: -0.75rem;
        transform: translateX(0);
        transition:
            transform 0.3s ease,
            text-shadow 0.3s ease;
        position: relative;

        &:hover {
            transform: translateX(5px);
            text-shadow: 0 0 3px var(--color-loafykitten);
        }

        &:after {
            content: '';
            position: absolute;
            left: 0;
            bottom: -2px;
            width: 100%;
            height: 2px;
            background-color: var(--color-loafykitten);
            transform: scaleX(0);
            transform-origin: right;
            transition: transform 0.3s ease;
        }

        &:hover:after {
            transform: scaleX(1);
            transform-origin: left;
        }
    }

    @media (max-width: 480px) {
        .info-container {
            padding: 1.25rem;
            border-radius: 0;
            border-left: none;
            border-right: none;
        }

        .author {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }

        .author-identity {
            gap: 0.75rem;
        }

        .author-name__primary {
            font-size: 1.15rem;
        }

        .author-name__secondary {
            font-size: 0.82rem;
        }

        .author-avatar img {
            width: 72px;
            height: 72px;
        }

        nav {
            flex-direction: row;
            gap: 1.25rem;
            align-items: baseline;

            & a {
                font-size: 1rem;
            }
        }
    }
</style>
