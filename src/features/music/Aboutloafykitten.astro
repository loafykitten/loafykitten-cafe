---
import aspectMusic from '@/assets/images/aspect-music.png'
import { Image } from 'astro:assets'
---

<section class="about-loafykitten" id="about-loafykitten">
    <div class="about-card">
        <div class="about-avatar">
            <div class="about-avatar__glow"></div>
            <Image src={aspectMusic} alt="loafykitten character art" />
        </div>

        <h2 class="about-name">loafykitten</h2>

        <div class="about-bio">
            <p>
                Hiii! I'm loafykitten, a silly little gal making lofi in her room with hopes and dreams. I'm a
                multi-instrumentalist, focusing on the piano, bass, and guitar. My music generally fits a sort of
                upbeat-melancholy, where the inspiration is from a sad place, but intended to be vibed to.
            </p>
            <p>
                Lofi is a fairly new adventure for me, but I've been involved with music my whole life. A few of my
                favorite artists are Sad Gatomon, Purrple Cat, Radwimps, and various anime/game composers.
            </p>
            <p>
                My music is 100% human / 0% AI! You can support human art by just being a fan! However if you'd like,
                you could also consider tipping my Ko-fi or joining my Patreon. ꨄ
            </p>
        </div>

        <div class="about-links">
            <a
                class="about-link about-link--kofi"
                href="https://www.ko-fi.com/loafykitten"
                target="_blank"
                rel="noopener noreferrer"
            >
                Tip Me
            </a>
            <a
                class="about-link about-link--patreon"
                href="https://patreon.com/loafykitten"
                target="_blank"
                rel="noopener noreferrer"
            >
                Become a Patron
            </a>
        </div>

        <button class="about-back" data-scroll-to="music-player-view" aria-label="Back to player">
            <span class="about-back__arrow">&uarr;</span> back to player
        </button>
    </div>
</section>

<script>
    const aboutSection = document.querySelector('.about-loafykitten')
    if (aboutSection) {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

        if (!prefersReducedMotion) {
            const observer = new IntersectionObserver(
                (entries) => {
                    for (const entry of entries) {
                        if (entry.isIntersecting) {
                            aboutSection.classList.add('is-visible')
                            observer.disconnect()
                        }
                    }
                },
                { threshold: 0.15 }
            )
            observer.observe(aboutSection)
        } else {
            aboutSection.classList.add('is-visible')
        }
    }
</script>

<style>
    .about-loafykitten {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        min-height: 100dvh;
        padding: 3rem 1rem;
        box-sizing: border-box;
    }

    .about-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
        max-width: 440px;
        width: 100%;
        padding: 2.5rem 2rem 2rem;
        box-sizing: border-box;
        background: rgba(0, 0, 0, 0.7);
        border: 1px solid rgba(221, 221, 221, 0.07);
        border-radius: 16px;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        box-shadow:
            0 8px 32px rgba(0, 0, 0, 0.5),
            inset 0 1px 0 rgba(119, 170, 255, 0.06);
        text-align: center;

        opacity: 0;
        transform: translateY(40px);
        transition:
            opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .is-visible .about-card {
        opacity: 1;
        transform: translateY(0);
    }

    .about-avatar {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .about-avatar__glow {
        position: absolute;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(119, 170, 255, 0.15) 0%, transparent 70%);
        pointer-events: none;
        animation: breathe 4s ease-in-out infinite;
    }

    .about-avatar img {
        position: relative;
        width: 140px;
        height: 140px;
        aspect-ratio: 1 / 1;
        border: 3px solid rgba(119, 170, 255, 0.5);
        border-radius: 50%;
        object-fit: cover;
        display: block;
        transition:
            transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
            box-shadow 0.4s ease,
            border-color 0.4s ease;
    }

    .about-avatar img:hover {
        transform: scale(1.05) rotate(5deg);
        box-shadow: 0 0 20px rgba(119, 170, 255, 0.3);
        border-color: #7af;
    }

    @keyframes breathe {
        0%,
        100% {
            transform: scale(1);
            opacity: 0.6;
        }
        50% {
            transform: scale(1.12);
            opacity: 1;
        }
    }

    .about-name {
        font-weight: 200;
        font-size: 1.4rem;
        letter-spacing: 0.08em;
        color: #7af;
        text-shadow:
            0 0 8px rgba(119, 170, 255, 0.4),
            0 0 20px rgba(119, 170, 255, 0.2);
        margin: 0;
    }

    .about-bio {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        max-width: 380px;
    }

    .about-bio p {
        font-size: 0.88rem;
        font-weight: 300;
        line-height: 1.7;
        color: #ccc;
        margin: 0;
        text-align: left;
    }

    .about-bio p:first-child {
        color: #ddd;
    }

    .about-links {
        display: flex;
        gap: 2rem;
        margin-top: 0.5rem;
    }

    .about-link {
        text-decoration: none;
        font-size: 1rem;
        font-weight: 300;
        letter-spacing: 0.03em;
        position: relative;
        transition: transform 0.2s ease;
    }

    .about-link:hover {
        transform: scale(1.05);
    }

    .about-link::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: -2px;
        width: 100%;
        height: 2px;
        transform: scaleX(0);
        transform-origin: right;
        transition: transform 0.3s ease;
    }

    .about-link:hover::after {
        transform: scaleX(1);
        transform-origin: left;
    }

    .about-link:focus-visible {
        outline: 2px solid #7af;
        outline-offset: 4px;
        border-radius: 2px;
    }

    .about-link--kofi {
        color: #bdeebb;
    }

    .about-link--kofi::after {
        background-color: #bdeebb;
    }

    .about-link--patreon {
        color: #f96854;
    }

    .about-link--patreon::after {
        background-color: #f96854;
    }

    .about-back {
        background: rgba(119, 170, 255, 0.06);
        border: 1px solid rgba(119, 170, 255, 0.2);
        border-radius: 9999px;
        color: #7af;
        font-size: 0.82rem;
        font-weight: 300;
        letter-spacing: 0.04em;
        cursor: pointer;
        font-family: inherit;
        padding: 0.4rem 1.25rem;
        margin-top: 0.5rem;
        transition:
            background 0.3s ease,
            border-color 0.3s ease,
            transform 0.2s ease;
    }

    .about-back:hover {
        background: rgba(119, 170, 255, 0.12);
        border-color: rgba(119, 170, 255, 0.4);
        transform: translateY(-2px);
    }

    .about-back__arrow {
        display: inline-block;
        transition: transform 0.3s ease;
    }

    .about-back:hover .about-back__arrow {
        transform: translateY(-2px);
    }

    .about-back:focus-visible {
        outline: 2px solid #7af;
        outline-offset: 4px;
        border-radius: 9999px;
    }

    .about-bio p {
        opacity: 0;
        transform: translateY(12px);
        transition:
            opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .is-visible .about-bio p:nth-child(1) {
        opacity: 1;
        transform: translateY(0);
        transition-delay: 0.3s;
    }

    .is-visible .about-bio p:nth-child(2) {
        opacity: 1;
        transform: translateY(0);
        transition-delay: 0.5s;
    }

    .is-visible .about-bio p:nth-child(3) {
        opacity: 1;
        transform: translateY(0);
        transition-delay: 0.7s;
    }

    .about-links {
        opacity: 0;
        transform: translateY(10px);
        transition:
            opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .is-visible .about-links {
        opacity: 1;
        transform: translateY(0);
        transition-delay: 0.9s;
    }

    @media (prefers-reduced-motion: reduce) {
        .about-card,
        .about-bio p,
        .about-links {
            opacity: 1;
            transform: none;
            transition: none;
        }

        .about-avatar__glow {
            animation: none;
        }

        .about-avatar img {
            transition: none;
        }
    }

    @media (max-width: 480px) {
        .about-loafykitten {
            padding: 2rem 0.75rem;
        }

        .about-card {
            padding: 2rem 1.25rem 1.5rem;
            border-radius: 12px;
        }

        .about-avatar img {
            width: 110px;
            height: 110px;
        }

        .about-avatar__glow {
            width: 140px;
            height: 140px;
        }

        .about-name {
            font-size: 1.2rem;
        }

        .about-bio p {
            font-size: 0.84rem;
        }

        .about-links {
            gap: 1.5rem;
            font-size: 0.9rem;
        }
    }
</style>
