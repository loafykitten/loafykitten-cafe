---
interface Props {
    socials: { href: string; name: string }[]
}

const { socials } = Astro.props
---

<div class="music-socials">
    {socials.map((social) => (
        <a href={social.href} target="_blank" rel="noopener noreferrer">
            {social.name}
        </a>
    ))}
</div>

<style>
    .music-socials {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .music-socials a {
        color: #7af;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 300;
        letter-spacing: 0.03em;
        position: relative;
        transition: transform 0.2s ease;

        &:hover {
            transform: scale(1.05);
        }

        &::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: -2px;
            width: 100%;
            height: 2px;
            background-color: #7af;
            transform: scaleX(0);
            transform-origin: right;
            transition: transform 0.3s ease;
        }

        &:hover::after {
            transform: scaleX(1);
            transform-origin: left;
        }
    }
</style>
